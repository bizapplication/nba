{
  "name": "nba",
  "private": true,
  "scripts": {
    "demo:doctor": "node --env-file=.env --experimental-strip-types scripts/demo-doctor.ts",
    "demo:setup": "node --env-file=.env --experimental-strip-types scripts/demo-setup.ts",
    "demo:start": "node --env-file=.env --experimental-strip-types scripts/demo-start.ts",
    "demo:stop": "node --env-file=.env --experimental-strip-types scripts/demo-stop.ts",
    "demo:seed": "node --env-file=.env --experimental-strip-types scripts/demo-seed.ts",
    "dev:web": "pnpm --filter @nba/web dev",
    "dev:crm:web": "bash ./scripts/dev-crm-web.sh",
    "seed:crm:demo": "pnpm --filter @nba/crm seed:demo",
    "dev:desktop": "pnpm --filter @nba/desktop dev",
    "dev:server": "pnpm --filter @nba/platform dev && pnpm --filter @nba/agent dev && pnpm --filter @nba/crm dev && pnpm --filter @nba/erp dev",
    "dev:cli": "pnpm --filter @nba/cli dev",
    "build:web": "pnpm --filter @nba/web build",
    "build:desktop": "pnpm --filter @nba/shared build && pnpm --filter @nba/desktop build",
    "build:cli": "pnpm --filter @nba/cli build",
    "preview:web": "pnpm --filter @nba/web preview",
    "test": "pnpm --filter '*' test",
    "lint": "pnpm --filter '*' lint",
    "typecheck": "pnpm --filter '*' typecheck"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0",
    "bun": ">=1.0.0"
  }
}
